<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFrameworks>net10.0;net10.0-android</TargetFrameworks>
    <AssemblyName>S2HD</AssemblyName>
    <LangVersion>12</LangVersion>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <AppendTargetFrameworkToOutputPath Condition="'$(TargetFramework)' == 'net10.0'">false</AppendTargetFrameworkToOutputPath>
    <ProjectGuid>{AB1C031B-CC43-4A01-9F35-B77FEC439639}</ProjectGuid>
    <DefaultItemExcludes>$(DefaultItemExcludes);$(MSBuildProjectDirectory)/external/**</DefaultItemExcludes>
    <DefaultItemExcludes>$(DefaultItemExcludes);$(MSBuildProjectDirectory)/packages/**</DefaultItemExcludes>
  </PropertyGroup>
  <PropertyGroup Condition="$([MSBuild]::IsOSPlatform('Windows'))">
    <DefineConstants>$(DefineConstants);WINDOWS_MESSAGE_BOX</DefineConstants>
  </PropertyGroup>
  <PropertyGroup Condition="'$(TargetFramework)' == 'net10.0-android'">
    <ApplicationId>org.sonicorca.s2hd</ApplicationId>
    <ApplicationDisplayVersion>1.0</ApplicationDisplayVersion>
    <ApplicationVersion>1</ApplicationVersion>
    <AndroidManifest>S2HD/Platforms/Android/AndroidManifest.xml</AndroidManifest>
    <RuntimeIdentifiers>android-arm64</RuntimeIdentifiers>
    <SupportedOSPlatformVersion>24</SupportedOSPlatformVersion>
    <RunAOTCompilation>false</RunAOTCompilation>
  </PropertyGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net10.0-android'">
    <AndroidAsset Include="data/**" />
    <AndroidAsset Include="Shaders/**" LogicalName="shaders/%(RecursiveDir)%(Filename)%(Extension)" />
    <AndroidJavaSource Remove="S2HD/Platforms/Android/java/**/*.java" />
    <AndroidJavaSource Include="S2HD/Platforms/Android/java/org/libsdl/app/*.java" Bind="false" />
  </ItemGroup>
  <PropertyGroup Condition="'$(Configuration)|$(Platform)' == 'Debug|AnyCPU'">
    <PlatformTarget>AnyCPU</PlatformTarget>
    <DebugType>full</DebugType>
    <Optimize>false</Optimize>
    <DefineConstants>DEBUG;TRACE</DefineConstants>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)|$(Platform)' == 'Release|AnyCPU'">
    <PlatformTarget>AnyCPU</PlatformTarget>
    <DebugType>pdbonly</DebugType>
    <Optimize>true</Optimize>
    <DefineConstants>TRACE</DefineConstants>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)|$(Platform)' == 'Debug|x64'">
    <PlatformTarget>x64</PlatformTarget>
    <OutputPath>bin\x64\Debug\</OutputPath>
    <DebugType>full</DebugType>
    <Optimize>false</Optimize>
    <DefineConstants>DEBUG;TRACE</DefineConstants>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)|$(Platform)' == 'Release|x64'">
    <PlatformTarget>x64</PlatformTarget>
    <OutputPath>bin\x64\Release\</OutputPath>
    <DebugType>pdbonly</DebugType>
    <Optimize>true</Optimize>
    <DefineConstants>TRACE</DefineConstants>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)|$(Platform)' == 'Debug|x86'">
    <PlatformTarget>x86</PlatformTarget>
    <OutputPath>bin\x86\Debug\</OutputPath>
    <DebugType>full</DebugType>
    <Optimize>false</Optimize>
    <DefineConstants>DEBUG;TRACE</DefineConstants>
  </PropertyGroup>
  <PropertyGroup Condition="'$(Configuration)|$(Platform)' == 'Release|x86'">
    <PlatformTarget>x86</PlatformTarget>
    <OutputPath>bin\x86\Release\</OutputPath>
    <DebugType>pdbonly</DebugType>
    <Optimize>true</Optimize>
    <DefineConstants>TRACE</DefineConstants>
  </PropertyGroup>
  <ItemGroup Condition="'$(TargetFramework)' != 'net10.0-android'">
    <Compile Remove="S2HD\Platforms\Android\**\*.cs" />
  </ItemGroup>
  <ItemGroup Condition="'$(TargetFramework)' == 'net10.0-android' And Exists('S2HD/Platforms/Android/libs/arm64-v8a/libSDL2.so')">
    <AndroidNativeLibrary Include="S2HD/Platforms/Android/libs/arm64-v8a/libSDL2.so" Abi="arm64-v8a" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="System.Collections.Immutable" Version="10.0.0" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="external\SonicOrca.Common\SonicOrca.Common.csproj" />
    <ProjectReference Include="external\SonicOrca.Drawing\SonicOrca.Drawing.csproj" />
    <ProjectReference Include="external\SonicOrca.Resources\SonicOrca.Resources.csproj" />
    <ProjectReference Include="external\SonicOrca.SDL2\SonicOrca.SDL2.csproj" />
    <ProjectReference Include="external\SonicOrca\SonicOrca.csproj" />
  </ItemGroup>
  <ItemGroup>
    <None Include="app.config" />
    <None Include="OpenTK.dll.config" Condition="'$(TargetFramework)' == 'net10.0'">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>
</Project>
